# Rosetta deploys with a GenLayer wallet key read from the working-directory root .env.
# Never commit real keys. Reference by variable name only.
#
# The deployer key for account 1 (signs the contract deploy and seeding):
GENLAYER_PRIVATE_KEY_1=0x...
#
# A second signer used only to seat party B during seeding (a_addr != b_addr):
GENLAYER_PRIVATE_KEY_7=0x...
#
# GitHub publishing (token-based, no gh auth switch):
GITHUB_1=your-github-username
GITHUB_TOKEN_1=ghp_...
